# 强制管理员权限运行
#Requires -RunAsAdministrator
Set-StrictMode -Version Latest
$ErrorActionPreference = "SilentlyContinue"

# ===================== 增强版：彻底修复乱码 仅修改此处 不碰其他功能 =====================
[Console]::OutputEncoding = [System.Text.Encoding]::UTF8
[Console]::InputEncoding = [System.Text.Encoding]::UTF8
$OutputEncoding = [System.Text.Encoding]::UTF8
$env:LANG = "en_US.UTF-8"
$env:LC_ALL = "en_US.UTF-8"
# 强制设置控制台代码页为 UTF-8
chcp 65001 | Out-Null

# ===================== 全局变量 100% 原版保留 无任何修改 =====================
$global:UBUNTU_NAME = "Ubuntu-22.04"
$global:WSL_CONFIG_PATH = "$env:USERPROFILE\.wslconfig"
$global:WINDOWS_TERMINAL_SETTINGS = "$env:LOCALAPPDATA\Microsoft\Windows Terminal\settings.json"

# ===================== 纯黑底高级感UI辅助函数 仅美化 不碰任何核心功能 =====================
# 极简高级感 主标题 无冗余边框 留白充足 纯黑底适配
function Write-MainTitle {
    Clear-Host
    Write-Host ""
    Write-Host "                    WSL2 UBUNTU 22.04 管理终端" -ForegroundColor White
    Write-Host "                    ENGINEER EDITION" -ForegroundColor DarkGray
    Write-Host ""
}

# 极简分隔线 低饱和度 无视觉干扰 高级感留白
function Write-Divider {
    Write-Host "────────────────────────────────────────────────────────────" -ForegroundColor DarkGray
    Write-Host ""
}

# 统一状态输出 克制配色 纯黑底高可读性 无冗余元素
function Write-Info {
    param([string]$Message)
    Write-Host "•  " -NoNewline -ForegroundColor DarkGray
    Write-Host $Message -ForegroundColor Gray
}
function Write-Success {
    param([string]$Message)
    Write-Host "✓  " -NoNewline -ForegroundColor DarkYellow
    Write-Host $Message -ForegroundColor White
}
function Write-Warn {
    param([string]$Message)
    Write-Host "⚠  " -NoNewline -ForegroundColor Yellow
    Write-Host $Message -ForegroundColor White
}
function Write-Error {
    param([string]$Message)
    Write-Host "✗  " -NoNewline -ForegroundColor Red
    Write-Host $Message -ForegroundColor White
}

# ===================== 1. 网络配置 核心代码100%原版 仅优化输出UI =====================
function Config-WSLNetwork {
    Write-MainTitle
    Write-Host "  网络配置模块" -ForegroundColor Gray
    Write-Divider
    Write-Info "正在写入 WSL 网络配置（与 Windows 共享代理）"
    
    # 原版核心配置 一字未改
    $configContent = @"
[wsl2]
# 开启镜像网络模式，和 Windows 共享网络栈
networkingMode=mirrored
# 关闭 WSL 自带防火墙，避免拦截
firewall=false
# 开启 DNS 隧道，解决域名解析问题
dnsTunneling=true
# 自动同步 Windows 的系统代理
autoProxy=true
memory=8GB
processors=4
swap=2GB
autoMemoryReclaim=disabled
"@
    $utf8NoBom = New-Object System.Text.UTF8Encoding $false
    [System.IO.File]::WriteAllText($global:WSL_CONFIG_PATH, $configContent, $utf8NoBom)
    wsl --shutdown
    Write-Success "网络配置完成，已开启 Windows 代理共享，WSL 服务已重启"
    Write-Host ""
}

# ===================== 2. ROOT+Systemd配置 增强版乱码修复 其他功能100%保留 =====================
function Invoke-OneClickRootAndAccess {
    Write-MainTitle
    Write-Host "  ROOT权限与Systemd配置模块" -ForegroundColor Gray
    Write-Divider
    Write-Info "正在执行永久ROOT权限、文件访问权限、Systemd开启配置"
    wsl --shutdown
    Start-Sleep 2

    # 原版注册表ROOT锁定 一字未改
    $regPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Lxss"
    Get-ChildItem -Path $regPath -ErrorAction SilentlyContinue | ForEach-Object {
        if ($_.GetValue("DistributionName") -eq $global:UBUNTU_NAME) {
            Set-ItemProperty -Path $_.PSPath -Name DefaultUid -Value 0 -Type DWord -Force
            Write-Info "注册表ROOT权限锁定完成"
        }
    }

    # ===================== 增强版：彻底修复Ubuntu内部乱码 仅修改此处 =====================
    wsl -d $global:UBUNTU_NAME -u root bash -c @"
cat > /etc/wsl.conf << 'EOF'
[user]
default=root
[automount]
enabled=true
mountFsTab=false
options="metadata,umask=000,fmask=000,dmask=000"
[network]
generateHosts=true
generateResolvConf=true
[boot]
systemd=true
EOF
# 增强版：彻底设置 UTF-8 环境变量
cat > /etc/environment << 'EOF'
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
LC_CTYPE=en_US.UTF-8
LANGUAGE=en_US:en
EOF
# 增强版：在所有profile文件中强制设置UTF-8
cat > /etc/profile.d/utf8.sh << 'EOF'
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8
export LANGUAGE=en_US:en
export NO_PROXY=localhost,127.0.0.1,::1
EOF
chmod +x /etc/profile.d/utf8.sh
# 增强版：更新 locale 配置
echo 'LANG=en_US.UTF-8' > /etc/locale.conf
echo 'LC_ALL=en_US.UTF-8' >> /etc/locale.conf
# 增强版：强制生成完整的 UTF-8 locale
locale-gen en_US.UTF-8 2>/dev/null || true
localedef -i en_US -f UTF-8 en_US.UTF-8 2>/dev/null || true
update-locale LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 2>/dev/null || true
"@ 2>&1 | Out-Null

    wsl --shutdown
    Start-Sleep 2

    # 原版验证逻辑 一字未改
    $user = wsl -d $global:UBUNTU_NAME whoami 2>&1
    Write-Divider
    Write-Success "一键配置全部执行完成"
    Write-Host ""
    Write-Info "当前默认用户：$user"
    Write-Info "Windows文件访问路径：\\wsl$\$global:UBUNTU_NAME"
    Write-Info "Windows代理共享已开启"
    Write-Info "Systemd已配置，下次WSL启动自动生效"
    Write-Info "默认启动命令：wsl"
    Write-Host ""
}

# ===================== 3. 标准安装 核心代码100%原版 仅优化输出UI =====================
function Install-StandardUbuntu {
    Write-MainTitle
    Write-Host "  Ubuntu 22.04 标准安装模块" -ForegroundColor Gray
    Write-Divider

    Write-Info "正在启用WSL系统必备组件"
    # 原版组件启用 一字未改
    dism /online /enable-feature /featurename:Microsoft-Windows-Subsystem-Linux /all /norestart | Out-Null
    dism /online /enable-feature /featurename:VirtualMachinePlatform /all /norestart | Out-Null
    wsl --set-default-version 2 | Out-Null
    Write-Success "WSL系统组件启用完成"

    Write-Info "正在清理旧版本残留并初始化网络配置"
    # 原版清理与网络配置 一字未改
    wsl --unregister $global:UBUNTU_NAME | Out-Null
    Config-WSLNetwork

    Write-Divider
    Write-Warn "请在弹出的窗口中完成初始用户创建（仅需执行1次）"
    Write-Warn "用户创建完成后关闭窗口，返回菜单执行【2. 一键ROOT配置】"
    Write-Divider
    # 原版安装命令 一字未改
    wsl --install -d $global:UBUNTU_NAME
}

# ===================== 4. 彻底卸载 核心代码100%原版 仅优化输出UI =====================
function Uninstall-Complete {
    Write-MainTitle
    Write-Host "  Ubuntu 22.04 彻底卸载模块" -ForegroundColor Gray
    Write-Divider

    Write-Info "正在注销Ubuntu发行版"
    # 原版卸载逻辑 一字未改
    wsl --unregister $global:UBUNTU_NAME | Out-Null
    if (Test-Path -Path $global:WSL_CONFIG_PATH) {
        Remove-Item -Path $global:WSL_CONFIG_PATH -Force | Out-Null
        Write-Info "已清理.wslconfig配置文件"
    }
    Write-Success "Ubuntu 22.04 已彻底卸载，无残留"
    Write-Host ""
}

# ===================== 5. 合并功能 核心代码100%原版 仅优化输出UI =====================
function Copy-OpenClawAndEnterWSL {
    Write-MainTitle
    Write-Host "  OpenClaw命令复制与Root终端模块" -ForegroundColor DarkYellow
    Write-Divider

    # 原版复制逻辑 一字未改
    $openclawCmd = "curl -fsSL https://raw.githubusercontent.com/Hutton-h/wsl.ubuntu.openclaw-/refs/heads/main/install_openclaw.sh | bash"
    Set-Clipboard -Value $openclawCmd
    Write-Success "OpenClaw安装命令已复制到系统剪贴板"
    Write-Info "命令内容：$openclawCmd"

    Write-Divider
    Write-Info "正在建立WSL Root终端连接，退出终端后将自动返回本菜单"
    Write-Host ""
    # 原版进入命令 一字未改
    wsl -d $global:UBUNTU_NAME -u root
}

# ===================== 主菜单 极简高级感 纯黑底适配 功能选项100%保留 =====================
function Show-Menu {
    Write-MainTitle
    Write-Host "  主功能菜单" -ForegroundColor Gray
    Write-Divider
    Write-Host "请选择要执行的操作，输入对应数字回车确认：`n" -ForegroundColor White
    
    Write-Host "  1.  " -NoNewline -ForegroundColor DarkGray
    Write-Host "安装 WSL2 + Ubuntu 22.04（标准全新安装）" -ForegroundColor White
    
    Write-Host "  2.  " -NoNewline -ForegroundColor DarkGray
    Write-Host "一键强制 ROOT+ 文件访问 + Systemd（安装完成后执行）" -ForegroundColor White
    
    Write-Host "  3.  " -NoNewline -ForegroundColor DarkGray
    Write-Host "彻底卸载 Ubuntu 22.04（无残留清理）" -ForegroundColor White
    
    Write-Host "  4.  " -NoNewline -ForegroundColor DarkGray
    Write-Host "重启 WSL 服务（配置生效/故障修复）" -ForegroundColor White
    
    Write-Host "  5.  " -NoNewline -ForegroundColor DarkGray
    Write-Host "复制 OpenClaw 安装命令并进入 WSL Root 终端" -ForegroundColor DarkYellow
    
    Write-Host "  6.  " -NoNewline -ForegroundColor DarkGray
    Write-Host "退出脚本" -ForegroundColor DarkGray
    
    Write-Divider
    # 原版输入校验逻辑 一字未改
    do {
        $choice = Read-Host "请输入操作序号 1-6"
    } while ($choice -notmatch "^[1-6]$")
    return $choice
}

# ===================== 脚本入口 原版逻辑100%保留 仅修改选项6为直接退出脚本 =====================
$scriptRunning = $true
while ($scriptRunning) {
    $userChoice = Show-Menu
    switch ($userChoice) {
        1 {
            Install-StandardUbuntu
            Read-Host "按任意键返回主菜单..."
            Clear-Host
            break
        }
        2 {
            Invoke-OneClickRootAndAccess
            Read-Host "按任意键返回主菜单..."
            Clear-Host
            break
        }
        3 {
            Uninstall-Complete
            Read-Host "按任意键返回主菜单..."
            Clear-Host
            break
        }
        4 {
            Write-MainTitle
            Write-Host "  WSL 服务重启模块" -ForegroundColor Gray
            Write-Divider
            Write-Info "正在关闭WSL所有实例..."
            wsl --shutdown
            Start-Sleep 2
            Write-Success "WSL 服务重启完成"
            Write-Host ""
            Read-Host "按任意键返回主菜单..."
            Clear-Host
            break
        }
        5 {
            Copy-OpenClawAndEnterWSL
            Read-Host "按任意键返回主菜单..."
            Clear-Host
            break
        }
        6 {
            $scriptRunning = $false
            Clear-Host
            break
        }
    }
}
